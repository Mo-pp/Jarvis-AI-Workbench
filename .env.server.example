# Low-memory server deployment template.
# Copy to `.env` on the server and replace secrets.
# This variant reuses existing MySQL, Redis, and OpenViking on the host.

COMPOSE_PROJECT_NAME=jarvis

# Host Nginx will proxy to this local-only web port.
JARVIS_WEB_PORT=18080
JARVIS_API_PORT=8084

# Existing MySQL exposed on the host. Your current server likely has the old
# Docker MySQL on 127.0.0.1:13306.
SPRING_DATASOURCE_URL=jdbc:mysql://host.docker.internal:13306/ai_resume?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change-this-mysql-password

# Existing Redis exposed on the host.
SPRING_DATA_REDIS_HOST=host.docker.internal
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=
SPRING_DATA_REDIS_DATABASE=0

# RabbitMQ will be started by docker-compose.server.yml.
RABBITMQ_DEFAULT_USER=jarvis
RABBITMQ_DEFAULT_PASS=change-this-rabbitmq-password

SPRING_PROFILES_ACTIVE=prod
JARVIS_SECURITY_KEY=replace-with-a-long-random-secret-at-least-32-chars
JARVIS_SECURITY_EXPIRE_HOURS=168

# LLM provider: gpt, zhipu, dashscope, or qianfan-coding-plan
JARVIS_LLM_PROVIDER=gpt
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini
OPENAI_WIRE_API=chat
OPENAI_TIMEOUT=120
BIGMODEL_API_KEY=
DASHSCOPE_API_KEY=
QIANFAN_OPENAI_API_KEY=

# Existing OpenViking exposed on the host.
OPENVIKING_BASE_URL=http://host.docker.internal:1933
OPENVIKING_API_KEY=
OPENVIKING_ACCOUNT=jarvis
OPENVIKING_USER=u-demo-001
OPENVIKING_AGENT=jarvis
OPENVIKING_PROVISIONING_REQUIRED=false
OPENVIKING_SESSION_ENABLED=false
OPENVIKING_RECALL_ENABLED=false

# Keep MCP off for first boot on the small server.
JARVIS_MCP_ENABLED=false
JARVIS_MCP_FAIL_FAST=false
JARVIS_MCP_BIGMODEL_WEB_SEARCH_ENABLED=false

MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_PROTOCOL=smtps

LANGCHAIN4J_HTTP_LOG_LEVEL=WARN
