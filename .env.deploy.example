# Copy this file to `.env` on the server and replace every placeholder.
# Do not commit `.env`.

COMPOSE_PROJECT_NAME=jarvis

# Public entry points
JARVIS_WEB_PORT=80
JARVIS_API_PORT=8084

# MySQL
MYSQL_DATABASE=ai_resume
MYSQL_ROOT_PASSWORD=change-this-mysql-root-password

# RabbitMQ, used by email verification jobs
RABBITMQ_DEFAULT_USER=jarvis
RABBITMQ_DEFAULT_PASS=change-this-rabbitmq-password

# Spring/Jarvis runtime
SPRING_PROFILES_ACTIVE=prod
JARVIS_SECURITY_KEY=replace-with-a-long-random-secret-at-least-32-chars
JARVIS_SECURITY_EXPIRE_HOURS=168

# LLM provider: gpt, zhipu, dashscope, or qianfan-coding-plan
JARVIS_LLM_PROVIDER=gpt
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.csprokit.cn/v1
OPENAI_MODEL=gpt-5.5
OPENAI_WIRE_API=chat
OPENAI_TIMEOUT=120
BIGMODEL_API_KEY=
DASHSCOPE_API_KEY=
QIANFAN_OPENAI_API_KEY=

# OpenViking integration
OPENVIKING_BASE_URL=http://your-openviking-host:1933
OPENVIKING_API_KEY=
OPENVIKING_ACCOUNT=jarvis
OPENVIKING_USER=u-demo-001
OPENVIKING_AGENT=jarvis
OPENVIKING_PROVISIONING_REQUIRED=true
OPENVIKING_SESSION_ENABLED=false
OPENVIKING_RECALL_ENABLED=false

# MCP is disabled by default for first deployment. Enable after BIGMODEL_API_KEY is configured.
JARVIS_MCP_ENABLED=false
JARVIS_MCP_FAIL_FAST=false
JARVIS_MCP_BIGMODEL_WEB_SEARCH_ENABLED=false

# Mail verification. MAIL_PASSWORD is the SMTP authorization code, not the login password.
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_PROTOCOL=smtps

# Logging
LANGCHAIN4J_HTTP_LOG_LEVEL=WARN
